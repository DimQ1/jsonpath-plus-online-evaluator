@page "/"
@inject IJSRuntime JS
@implements IAsyncDisposable
@using System.Text.Json
@using JsonPathPlus.Evaluator.Workers

@* Provided by _Imports: System.Text.Json.Nodes, JsonPathPlus.Evaluator.Services *@

@* ========== CODE BEHIND ========== *@
@code {
    // ===== Sample Data =====
