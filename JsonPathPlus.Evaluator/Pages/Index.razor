<div class="evaluator-header">
    <div class="evaluator-title">
        <span class="icon">&#x1F50D;</span>
        <span>JsonPathPlus Online Evaluator</span>
        <span class="version">v1.1.0</span>
    </div>
    <div class="header-actions">
        <button class="btn @(showHistory ? "active" : "")" @onclick="ToggleHistory" title="Evaluation history">
            <span>&#x1F552;</span> History
            @if (historyEntries.Count > 0)
            {
                <span class="badge">@historyEntries.Count</span>
            }
        </button>
        <button class="btn" @onclick="ResetAsync" title="Clear inputs and reset to sample">
            <span>&#x21BA;</span> Reset
        </button>
        <button class="btn" @onclick="ShareAsync" title="Copy shareable URL to clipboard">
            <span>&#x1F517;</span> Share
        </button>
        <a class="btn" href="https://www.nuget.org/packages/JsonPathPlus" target="_blank" title="JsonPathPlus NuGet package">
            <span>&#x1F4E6;</span> NuGet
        </a>
        <a class="btn" href="https://github.com/Dimq1/JsonPathPlus" target="_blank" title="JsonPathPlus source on GitHub">
            <span>&#x2B55;</span> GitHub
        </a>
    </div>
</div>

@* ========== PATH INPUT BAR ========== *@
<div class="path-input-bar">
    <label for="pathInput">JSONPath</label>
    <input id="pathInput"
           @ref="pathInputRef"
           class="path-input @(HasPathError ? "error" : (HasResults ? "success" : ""))"
           type="text"
           value="@_pathInput"
           placeholder="e.g. $.store.book[*].title"
           spellcheck="false" />
    <div class="match-mode-toggle">
        <button class="@(showFirstOnly ? "active" : "")"
                @onclick="() => SetMode(true)"
                title="Show only the first match">
            First
        </button>
        <button class="@(showFirstOnly ? "" : "active")"
                @onclick="() => SetMode(false)"
                title="Show all matches">
            All
        </button>
    </div>
</div>

@* ========== MAIN PANELS ========== *@
<div class="panels-container @(showHistory ? "has-history" : "")">
    @* History Sidebar *@
    @if (showHistory)
    {
        <div class="panel history-sidebar">
            <div class="panel-header">
                <span>History</span>
                <button class="btn" @onclick="ClearHistoryAsync" title="Clear all history">
                    <span>&#x1F5D1;</span> Clear
                </button>
            </div>
            <div class="panel-body">
                <div class="history-list">
                    @if (historyEntries.Count == 0)
                    {
                        <div class="history-empty">No history yet. Evaluate some expressions to see them here.</div>
                    }
                    else
                    {
                        @foreach (var entry in historyEntries)
                        {
                            <div class="history-item" @onclick="() => RestoreFromHistory(entry)" title="Restore this evaluation">
                                <div class="history-item-path">@entry.Path</div>
                                <div class="history-item-meta">
                                    <span class="history-item-count">@entry.MatchCount match@(entry.MatchCount == 1 ? "" : "es")</span>
                                    <span class="history-item-time">@entry.Timestamp</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }

    @* Left: JSON Document *@
    <div class="panel document-panel">
        <div class="panel-header">
            <span>Document</span>
            <InputFile OnChange="OnFileSelected" accept=".json" style="display:none" id="fileInput" />
            <button class="btn" @onclick="OpenFilePicker" title="Import a .json file from disk">
                <span>&#x1F4C2;</span> Import File
            </button>
        </div>
        <div class="panel-body">
            <div class="editor-surface monaco-surface @(HasJsonError ? "error" : "")" @onclick="FocusJsonEditorAsync">
                <div class="monaco-host" @ref="jsonMonacoRef" aria-label="JSON document editor"></div>
            </div>
        </div>
        @if (HasJsonError && !string.IsNullOrEmpty(jsonError))
        {
            <div class="error-message">@jsonError</div>
        }
    </div>

    @* Right: Evaluation Results *@
    <div class="panel results-panel">
        <div class="panel-header">
            <span>@(ShowOutputPaths ? "Output Paths" : "Evaluation Results")</span>
            <div class="panel-header-actions">
                <label class="header-toggle" title="Show JSONPath locations instead of matched values">
                    <input type="checkbox" @bind="ShowOutputPaths" />
                    <span>Output Paths</span>
                </label>
                @if (isEvaluating)
                {
                    <span class="evaluation-status" aria-live="polite">
                        <span class="evaluation-spinner" aria-hidden="true"></span>
                        <span>Evaluating...</span>
                    </span>
                }
                else
                {
                    <span class="match-count @(matchCount == 0 ? "zero" : "")">
                        @matchCount match@(matchCount == 1 ? "" : "es")
                    </span>
                }
            </div>
        </div>
        <div class="panel-body">
            <div class="editor-surface result-surface @(HasPathError ? "error" : "")">
                <div class="monaco-host" @ref="resultMonacoRef" aria-label="Evaluation results editor"></div>
            </div>
        </div>
    </div>
</div>

@* ========== SYNTAX REFERENCE ========== *@
<details class="syntax-reference">
    <summary>Syntax Reference</summary>
    <table class="syntax-table">
        <thead>
            <tr>
                <th style="width:35%">Syntax</th>
                <th style="width:50%">Description</th>
                <th style="width:15%">Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (example, description) in SyntaxRows)
            {
                <tr>
                    <td>
                        <span class="syntax-example"
                              @onclick="() => UseSyntaxExample(example)"
                              title="Click to try this example">
                            @example
                        </span>
                    </td>
                    <td class="syntax-desc">@description</td>
                    <td><span class="syntax-status">&#x2714; Supported</span></td>
                </tr>
            }
        </tbody>
    </table>
</details>

@* ========== TOAST NOTIFICATION ========== *@
@if (showToast)
{
    <div class="toast">@toastMessage</div>
}


