<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net11.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="11.0.0-preview.5.26302.115" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="11.0.0-preview.5.26302.115" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup Condition="Exists('..\..\JsonPathPlus\JsonPathPlus.csproj')">
    <ProjectReference Include="..\..\JsonPathPlus\JsonPathPlus.csproj" />
  </ItemGroup>

  <ItemGroup Condition="!Exists('..\..\JsonPathPlus\JsonPathPlus.csproj')">
    <PackageReference Include="JsonPathPlus" Version="1.8.0" />
  </ItemGroup>

</Project>
